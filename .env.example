# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mca_secure_password_2026

# Redis
REDIS_URL=redis://localhost:6379

# Optional external APIs (leave empty for RSS + simulated weather)
WEATHER_API_KEY=
NEWS_API_KEY=

# Kafka (enable in docker-compose profile + set KAFKA_ENABLED=true on worker/backend)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Security — change in production
SECRET_KEY=generate-a-long-random-secret

# Frontend (empty = same-origin via nginx gateway on :80)
VITE_API_URL=
